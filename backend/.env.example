MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/domusvesta
# Optional: override DNS resolvers used for MongoDB Atlas SRV lookups.
MONGODB_DNS_SERVERS=1.1.1.1,8.8.8.8,8.8.4.4
JWT_SECRET=replace-with-a-secure-secret
PORT=5000

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

OPENAI_API_KEY=optional-for-existing-langchain-agent
OPENAI_MODEL=gpt-4o-mini

N8N_GET_QUOTE_WEBHOOK_URL=https://your-n8n-domain/webhook/domusvesta/get-quote
N8N_MATCH_PROVIDER_WEBHOOK_URL=https://your-n8n-domain/webhook/domusvesta/match-provider
N8N_BOOK_SERVICE_WEBHOOK_URL=https://your-n8n-domain/webhook/domusvesta/book-service
N8N_WEBHOOK_SECRET=replace-with-a-shared-webhook-secret
